# ─────────────────────────────────────────────────────────────────────────────
# frontend/.gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment  ⚠️  NEVER commit real secrets ────────────────────────────────
.env
.env.*
!.env.example

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js build output ─────────────────────────────────────────────────────
.next/
out/
build/

# ── TypeScript build info ─────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Test coverage ────────────────────────────────────────────────────────────
coverage/

# ── Vercel deployment ─────────────────────────────────────────────────────────
.vercel

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Certificates / keys ───────────────────────────────────────────────────────
*.pem
*.key
*.cert
*.p12
*.pfx

# ── OS / Editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
