# ─────────────────────────────────────────────────────────────────────────────
# Root-level .gitignore  (RoyalPropertyFinder monorepo)
# ─────────────────────────────────────────────────────────────────────────────

# ── OS / Editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Environment files  ⚠️  NEVER commit real secrets ──────────────────────────
.env
.env.*
!.env.example          # the template (no real values) is allowed

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
jspm_packages/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Project Specific ───────────────────────────────────────────────────────
docs/
