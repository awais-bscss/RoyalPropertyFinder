# ─────────────────────────────────────────────────────────────────────────────
# backend/.gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment  ⚠️  NEVER commit real secrets ────────────────────────────────
.env
.env.*
!.env.example

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
jspm_packages/

# ── Build output ─────────────────────────────────────────────────────────────
dist/
dist-server/
build/

# ── Uploaded user files  (keep folder structure via .gitkeep) ────────────────
uploads/**/!.gitkeep

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ── Runtime / diagnostics ────────────────────────────────────────────────────
pids/
*.pid
*.seed
*.pid.lock
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ── Test coverage ────────────────────────────────────────────────────────────
coverage/

# ── OS / Editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.sublime-workspace
*.launch
.settings/
.classpath
.project
.c9/
