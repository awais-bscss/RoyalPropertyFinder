# ─────────────────────────────────────────────────────────────────────────────
# backend/.env.example
# Copy this file to .env and fill in your own values.
# ⚠️  NEVER commit .env — it contains real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Get your connection string from https://cloud.mongodb.com
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────────────────────────────────
# Use a long random string — e.g. run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_64_char_random_hex_string
JWT_EXPIRE=30d

# ── Session (Passport.js) ────────────────────────────────────────────────────
SESSION_SECRET=replace_with_a_64_char_random_hex_string

# ── Google OAuth 2.0 ─────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ── Facebook OAuth ───────────────────────────────────────────────────────────
# Create an app at https://developers.facebook.com → My Apps
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:5000/api/v1/auth/facebook/callback

# Cloudinary
CLOUDINARY_CLOUD_NAME=your cloud name 
CLOUDINARY_API_KEY=Your Api Key
CLOUDINARY_API_SECRET=Your Api Secret